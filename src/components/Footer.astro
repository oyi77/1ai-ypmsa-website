---
/**
 * Footer.astro — Dark 4-column footer
 * Brand, Link Cepat, Program Unggulan, Hubungi Kami
 * Social icons, newsletter form, copyright bar
 */
---

<footer class="bg-neutral-900" role="contentinfo">
  <!-- Main footer content -->
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">

      <!-- ─── Column 1: Brand ─── -->
      <div class="sm:col-span-2 lg:col-span-1">
        <!-- Logo -->
        <a href="/" class="inline-flex items-center gap-3 group" aria-label="YPSMA — Beranda">
          <img
            src="/images/logoypma.png"
            alt="Logo YPSMA"
            class="h-10 w-10 rounded-lg object-cover"
            loading="lazy"
          />
          <span class="font-heading text-xl font-extrabold text-white">YPSMA</span>
        </a>

        <p class="mt-4 max-w-xs text-sm leading-relaxed text-neutral-400">
          Yayasan Pendidikan Sinar Matahari — lembaga pendidikan Islam terpadu yang
          menggabungkan kurikulum nasional dengan pendidikan Al-Quran dan pembinaan akhlak
          mulia bagi generasi muda Indonesia.
        </p>

        <!-- Social icons -->
        <div class="mt-6 flex items-center gap-4">
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/profile.php?id=61567098697530"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-neutral-800 text-neutral-400 transition-colors hover:bg-primary-500 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
            aria-label="Facebook YPSMA"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/yayasan.ypsma"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-neutral-800 text-neutral-400 transition-colors hover:bg-primary-500 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
            aria-label="Instagram YPSMA"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
          <!-- YouTube -->
          <a
            href="https://www.youtube.com/@YPSMAJombang"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-neutral-800 text-neutral-400 transition-colors hover:bg-primary-500 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
            aria-label="YouTube YPSMA"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- ─── Column 2: Link Cepat ─── -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-white">
          Link Cepat
        </h3>
        <ul class="mt-4 space-y-3" role="list">
          <li>
            <a href="#beranda" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Beranda
            </a>
          </li>
          <li>
            <a href="#tentang" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Tentang Kami
            </a>
          </li>
          <li>
            <a href="#program" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Program
            </a>
          </li>
          <li>
            <a href="#galeri" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Galeri
            </a>
          </li>
          <li>
            <a href="#donasi" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Donasi
            </a>
          </li>
        </ul>
      </div>

      <!-- ─── Column 3: Program Unggulan ─── -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-white">
          Program Unggulan
        </h3>
        <ul class="mt-4 space-y-3" role="list">
          <li>
            <a href="#program" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Tahfidz Al-Quran
            </a>
          </li>
          <li>
            <a href="#program" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Kurikulum Nasional
            </a>
          </li>
          <li>
            <a href="#program" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Pembinaan Akhlak
            </a>
          </li>
          <li>
            <a href="#program" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Pesantren Kilat
            </a>
          </li>
          <li>
            <a href="#program" class="text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400">
              Beasiswa Santri
            </a>
          </li>
        </ul>
      </div>

      <!-- ─── Column 4: Hubungi Kami + Newsletter ─── -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-white">
          Hubungi Kami
        </h3>
        <ul class="mt-4 space-y-3" role="list">
          <li>
            <a
              href="https://wa.me/6282234551160"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
            >
              <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +62 822-3455-1160
            </a>
          </li>
          <li>
            <a
              href="mailto:info@ypsma.org"
              class="inline-flex items-center gap-2 text-sm text-neutral-400 transition-colors hover:text-primary-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
            >
              <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              info@ypsma.org
            </a>
          </li>
          <li class="pt-1 text-sm leading-relaxed text-neutral-500">
            Jl. Diponegoro No. 34, Gondek,<br />
            Mojowarno, Jombang, Jawa Timur
          </li>
        </ul>

        <!-- Newsletter (decorative) -->
        <div class="mt-6">
          <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500">
            Newsletter
          </h4>
          <form class="mt-3 flex gap-2" onsubmit="event.preventDefault()" aria-label="Langganan newsletter">
            <label for="footer-email" class="sr-only">Alamat email</label>
            <input
              id="footer-email"
              type="email"
              placeholder="Email Anda"
              required
              class="min-w-0 flex-1 rounded-lg bg-neutral-800 px-4 py-2.5 text-sm text-white placeholder-neutral-500 ring-1 ring-neutral-700 transition-all focus:ring-2 focus:ring-primary-500 focus:outline-none"
            />
            <button
              type="submit"
              class="shrink-0 rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-400"
            >
              Kirim
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================================
       Bottom bar
       ============================================================ -->
  <div class="border-t border-neutral-800">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 py-6 sm:flex-row sm:px-6 lg:px-8">
      <p class="text-xs text-neutral-500">
        &copy; 2025 YPSMA Yayasan Pendidikan Sinar Matahari. All Rights Reserved.
      </p>
      <p class="text-xs text-neutral-500">
        Dibuat dengan <span aria-hidden="true">&hearts;</span><span class="sr-only">cinta</span> untuk pendidikan Indonesia
      </p>
    </div>
  </div>
</footer>
