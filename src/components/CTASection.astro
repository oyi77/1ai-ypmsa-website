---
/**
 * CTASection — Siap Menjadi Bagian dari Keluarga YPSMA?
 * Full-width gradient CTA with decorative elements
 * Two buttons: gold bg + white outline
 * Stats row reinforcement
 * Zero client-side JS
 */
---

<section class="relative overflow-hidden bg-gradient-to-br from-[var(--color-primary-800)] to-[var(--color-primary-900)] py-16 md:py-20">

  <!-- Decorative floating circles -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <!-- Large circle top-right -->
    <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-[var(--color-primary-600)]/20"></div>
    <!-- Medium circle bottom-left -->
    <div class="absolute -bottom-16 -left-16 h-48 w-48 rounded-full bg-[var(--color-primary-500)]/15"></div>
    <!-- Small circle mid-right -->
    <div class="absolute bottom-10 right-1/4 h-20 w-20 rounded-full bg-[var(--color-secondary-500)]/10"></div>
    <!-- Small circle top-left -->
    <div class="absolute left-1/3 top-8 h-14 w-14 rounded-full bg-[var(--color-primary-400)]/10"></div>
    <!-- Tiny circle center -->
    <div class="absolute left-1/2 top-1/2 h-6 w-6 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--color-secondary-400)]/10"></div>
    <!-- Subtle dot pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
  </div>

  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">

    <!-- Heading -->
    <h2 class="mb-4 font-[var(--font-heading)] text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
      Siap Menjadi Bagian dari<br class="hidden sm:inline" /> Keluarga YPSMA?
    </h2>

    <!-- Subheading -->
    <p class="mx-auto mb-8 max-w-2xl text-base leading-relaxed text-[var(--color-primary-100)] sm:text-lg">
      Daftarkan putra-putri Anda sekarang dan berikan mereka bekal ilmu serta iman
      untuk masa depan yang gemilang. Bersama YPSMA, wujudkan pendidikan impian.
    </p>

    <!-- Buttons -->
    <div class="mb-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/daftar"
        class="inline-flex w-full items-center justify-center rounded-lg bg-[var(--color-secondary-500)] px-8 py-3.5 font-[var(--font-heading)] text-sm font-bold text-[var(--color-neutral-900)] shadow-lg transition-all duration-200 hover:bg-[var(--color-secondary-600)] hover:shadow-xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-secondary-500)] sm:w-auto"
      >
        Daftar Sekarang
      </a>
      <a
        href="/kontak"
        class="inline-flex w-full items-center justify-center rounded-lg border-2 border-white/30 bg-transparent px-8 py-3.5 font-[var(--font-heading)] text-sm font-bold text-white transition-all duration-200 hover:border-white/60 hover:bg-white/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:w-auto"
      >
        Hubungi Kami
      </a>
    </div>

    <!-- Stats row -->
    <div class="mx-auto flex max-w-lg items-center justify-center divide-x divide-white/20">
      <div class="flex-1 px-4 py-2 text-center">
        <span class="block font-[var(--font-heading)] text-xl font-extrabold text-[var(--color-secondary-400)]">500+</span>
        <span class="text-xs font-medium text-[var(--color-primary-200)]">Siswa</span>
      </div>
      <div class="flex-1 px-4 py-2 text-center">
        <span class="block font-[var(--font-heading)] text-xl font-extrabold text-[var(--color-secondary-400)]">50+</span>
        <span class="text-xs font-medium text-[var(--color-primary-200)]">Guru</span>
      </div>
      <div class="flex-1 px-4 py-2 text-center">
        <span class="block font-[var(--font-heading)] text-xl font-extrabold text-[var(--color-secondary-400)]">15+</span>
        <span class="text-xs font-medium text-[var(--color-primary-200)]">Tahun</span>
      </div>
    </div>
  </div>
</section>
