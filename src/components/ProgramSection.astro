---
/**
 * ProgramSection — Program Unggulan
 * 6 cards in responsive grid (1→2→3 cols)
 * Each card: SVG icon, title, description, CTA link
 * Top border accent, hover shadow
 */
---

<section id="program" class="bg-[var(--color-neutral-50)] py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mx-auto mb-12 max-w-2xl text-center md:mb-16">
      <span class="mb-3 inline-block rounded-full bg-[var(--color-primary-50)] px-4 py-1.5 font-[var(--font-heading)] text-sm font-semibold tracking-wide text-[var(--color-primary-600)]">
        Program Kami
      </span>
      <h2 class="mb-3 font-[var(--font-heading)] text-3xl font-extrabold tracking-tight text-[var(--color-neutral-900)] sm:text-4xl">
        Program Unggulan
      </h2>
      <!-- Gold underline -->
      <div class="mx-auto mb-5 h-1 w-16 rounded-full bg-[var(--color-secondary-500)]"></div>
      <p class="text-[var(--color-neutral-600)] leading-relaxed">
        Enam pilar pendidikan yang dirancang secara komprehensif untuk mengembangkan potensi
        santri secara menyeluruh — ilmu, akhlak, keterampilan, dan keimanan.
      </p>
    </div>

    <!-- Program Cards Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">

      <!-- 1. Pendidikan Qurani -->
      <article class="group rounded-lg bg-white shadow-[var(--shadow-sm)] transition-all duration-300 hover:shadow-[var(--shadow-lg)] border-t-4 border-[var(--color-primary-500)]">
        <div class="p-6">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[var(--color-primary-50)] text-[var(--color-primary-600)] transition-colors group-hover:bg-[var(--color-primary-500)] group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
              <path d="M8 7h6"/>
              <path d="M8 11h4"/>
            </svg>
          </div>
          <h3 class="mb-2 font-[var(--font-heading)] text-lg font-bold text-[var(--color-neutral-900)]">
            Pendidikan Qurani
          </h3>
          <p class="mb-4 text-sm leading-relaxed text-[var(--color-neutral-600)]">
            Kurikulum terpadu yang mengintegrasikan hafalan Al-Qur'an dengan mata pelajaran
            umum, memastikan santri memahami dan mengamalkan ajaran Islam dalam kehidupan sehari-hari.
          </p>
          <img
            src="/images/kelas1.png"
            alt="Kelas Pendidikan Qurani YPSMA"
            class="mb-4 h-40 w-full rounded-md object-cover"
            loading="lazy"
          />
          <a
            href="/program#qurani"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-primary-600)] transition-colors hover:text-[var(--color-primary-700)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary-500)]"
          >
            Selengkapnya
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </article>

      <!-- 2. Tahfidz -->
      <article class="group rounded-lg bg-white shadow-[var(--shadow-sm)] transition-all duration-300 hover:shadow-[var(--shadow-lg)] border-t-4 border-[var(--color-primary-500)]">
        <div class="p-6">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[var(--color-primary-50)] text-[var(--color-primary-600)] transition-colors group-hover:bg-[var(--color-primary-500)] group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
              <path d="m15 5 4 4"/>
            </svg>
          </div>
          <h3 class="mb-2 font-[var(--font-heading)] text-lg font-bold text-[var(--color-neutral-900)]">
            Tahfidz Al-Qur'an
          </h3>
          <p class="mb-4 text-sm leading-relaxed text-[var(--color-neutral-600)]">
            Program intensif hafalan Al-Qur'an dengan target Juz 30 di SD dan Juz 28-30 di SMP.
            Metode muraja'ah dan tilawah terjadwal memastikan hafalan mantap dan berkualitas.
          </p>
          <img
            src="/images/Tahfidz.png"
            alt="Kegiatan Tahfidz Al-Qur'an YPSMA"
            class="mb-4 h-40 w-full rounded-md object-cover"
            loading="lazy"
          />
          <a
            href="/program#tahfidz"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-primary-600)] transition-colors hover:text-[var(--color-primary-700)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary-500)]"
          >
            Selengkapnya
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </article>

      <!-- 3. Akhlak & Adab -->
      <article class="group rounded-lg bg-white shadow-[var(--shadow-sm)] transition-all duration-300 hover:shadow-[var(--shadow-lg)] border-t-4 border-[var(--color-primary-500)]">
        <div class="p-6">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[var(--color-secondary-50)] text-[var(--color-secondary-600)] transition-colors group-hover:bg-[var(--color-secondary-500)] group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            </svg>
          </div>
          <h3 class="mb-2 font-[var(--font-heading)] text-lg font-bold text-[var(--color-neutral-900)]">
            Akhlak &amp; Adab
          </h3>
          <p class="mb-4 text-sm leading-relaxed text-[var(--color-neutral-600)]">
            Pembentukan karakter islami melalui pembiasaan adab sehari-hari, sholat berjamaah,
            dzikir pagi, dan bimbingan akhlak oleh ustadz/ustadzah yang berpengalaman.
          </p>
          <img
            src="/images/kelas2.png"
            alt="Pembelajaran akhlak dan adab di YPSMA"
            class="mb-4 h-40 w-full rounded-md object-cover"
            loading="lazy"
          />
          <a
            href="/program#akhlak"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-primary-600)] transition-colors hover:text-[var(--color-primary-700)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary-500)]"
          >
            Selengkapnya
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </article>

      <!-- 4. STEM Islam -->
      <article class="group rounded-lg bg-white shadow-[var(--shadow-sm)] transition-all duration-300 hover:shadow-[var(--shadow-lg)] border-t-4 border-[var(--color-primary-500)]">
        <div class="p-6">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[var(--color-primary-50)] text-[var(--color-primary-600)] transition-colors group-hover:bg-[var(--color-primary-500)] group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 3h12l4 6-10 13L2 9Z"/>
              <path d="M11 3 8 9l4 13 4-13-3-6"/>
              <path d="M2 9h20"/>
            </svg>
          </div>
          <h3 class="mb-2 font-[var(--font-heading)] text-lg font-bold text-[var(--color-neutral-900)]">
            STEM Islam
          </h3>
          <p class="mb-4 text-sm leading-relaxed text-[var(--color-neutral-600)]">
            Integrasi sains, teknologi, teknik, dan matematika dengan nilai-nilai Islam.
            Laboratorium komputer dan sains modern untuk mempersiapkan santri di era digital.
          </p>
          <img
            src="/images/labkomputer.png"
            alt="Lab komputer STEM Islam YPSMA"
            class="mb-4 h-40 w-full rounded-md object-cover"
            loading="lazy"
          />
          <a
            href="/program#stem"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-primary-600)] transition-colors hover:text-[var(--color-primary-700)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary-500)]"
          >
            Selengkapnya
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </article>

      <!-- 5. Seni & Kaligrafi -->
      <article class="group rounded-lg bg-white shadow-[var(--shadow-sm)] transition-all duration-300 hover:shadow-[var(--shadow-lg)] border-t-4 border-[var(--color-primary-500)]">
        <div class="p-6">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[var(--color-secondary-50)] text-[var(--color-secondary-600)] transition-colors group-hover:bg-[var(--color-secondary-500)] group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="13.5" cy="6.5" r="2.5"/>
              <path d="M17.5 10.5c0-2.5-2-4-4-4s-4 1.5-4 4"/>
              <path d="M4 20c0-4 3-7 8-7s8 3 8 7"/>
            </svg>
          </div>
          <h3 class="mb-2 font-[var(--font-heading)] text-lg font-bold text-[var(--color-neutral-900)]">
            Seni &amp; Kaligrafi
          </h3>
          <p class="mb-4 text-sm leading-relaxed text-[var(--color-neutral-600)]">
            Pengembangan bakat seni islami melalui kaligrafi Arab, seni lukis, dan seni
            musik islami. Ekstrakurikuler seni yang memperkaya ruhani santri.
          </p>
          <img
            src="/images/perpustakaan.png"
            alt="Perpustakaan dan ruang seni YPSMA"
            class="mb-4 h-40 w-full rounded-md object-cover"
            loading="lazy"
          />
          <a
            href="/program#seni"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-primary-600)] transition-colors hover:text-[var(--color-primary-700)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary-500)]"
          >
            Selengkapnya
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </article>

      <!-- 6. Olahraga Sunnah -->
      <article class="group rounded-lg bg-white shadow-[var(--shadow-sm)] transition-all duration-300 hover:shadow-[var(--shadow-lg)] border-t-4 border-[var(--color-primary-500)]">
        <div class="p-6">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[var(--color-primary-50)] text-[var(--color-primary-600)] transition-colors group-hover:bg-[var(--color-primary-500)] group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
          </div>
          <h3 class="mb-2 font-[var(--font-heading)] text-lg font-bold text-[var(--color-neutral-900)]">
            Olahraga Sunnah
          </h3>
          <p class="mb-4 text-sm leading-relaxed text-[var(--color-neutral-600)]">
            Aktivitas fisik sunnah seperti renang, memanah, dan berkuda yang dianjurkan
            dalam Islam. Fasilitas olahraga lengkap untuk kesehatan jasmani dan rohani.
          </p>
          <img
            src="/images/senam.png"
            alt="Kegiatan olahraga sunnah di YPSMA"
            class="mb-4 h-40 w-full rounded-md object-cover"
            loading="lazy"
          />
          <a
            href="/program#olahraga"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-primary-600)] transition-colors hover:text-[var(--color-primary-700)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary-500)]"
          >
            Selengkapnya
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </article>

    </div>
  </div>
</section>
