---
/**
 * StatsSection — Key statistics bar
 * Full-width dark primary bg, 4 stat cards (2x2 mobile, 4-col desktop)
 * Zero JS — static numbers
 */
---

<section class="relative overflow-hidden bg-[var(--color-primary-900)] py-14 md:py-20">
  <!-- Subtle gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary-800)] via-[var(--color-primary-900)] to-[var(--color-primary-900)] opacity-80"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-primary-700)_0%,_transparent_60%)] opacity-20"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-8">

      <!-- Stat 1: Siswa -->
      <div class="group text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-primary-700)]/50 transition-colors group-hover:bg-[var(--color-primary-600)]/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-secondary-400)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <span class="mb-1 block font-[var(--font-heading)] text-4xl font-extrabold text-[var(--color-secondary-400)] md:text-5xl">
          500<span class="text-[var(--color-secondary-300)]">+</span>
        </span>
        <span class="text-sm font-medium text-[var(--color-primary-200)]">Siswa Berprestasi</span>
      </div>

      <!-- Stat 2: Pengajar -->
      <div class="group text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-primary-700)]/50 transition-colors group-hover:bg-[var(--color-primary-600)]/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-secondary-400)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 14a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
            <path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"/>
          </svg>
        </div>
        <span class="mb-1 block font-[var(--font-heading)] text-4xl font-extrabold text-[var(--color-secondary-400)] md:text-5xl">
          50<span class="text-[var(--color-secondary-300)]">+</span>
        </span>
        <span class="text-sm font-medium text-[var(--color-primary-200)]">Pengajar Profesional</span>
      </div>

      <!-- Stat 3: Tahun -->
      <div class="group text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-primary-700)]/50 transition-colors group-hover:bg-[var(--color-primary-600)]/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-secondary-400)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <span class="mb-1 block font-[var(--font-heading)] text-4xl font-extrabold text-[var(--color-secondary-400)] md:text-5xl">
          15<span class="text-[var(--color-secondary-300)]">+</span>
        </span>
        <span class="text-sm font-medium text-[var(--color-primary-200)]">Tahun Mengabdi</span>
      </div>

      <!-- Stat 4: Program Qurani -->
      <div class="group text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-primary-700)]/50 transition-colors group-hover:bg-[var(--color-primary-600)]/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-secondary-400)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
          </svg>
        </div>
        <span class="mb-1 block font-[var(--font-heading)] text-4xl font-extrabold text-[var(--color-secondary-400)] md:text-5xl">
          100<span class="text-[var(--color-secondary-300)]">%</span>
        </span>
        <span class="text-sm font-medium text-[var(--color-primary-200)]">Program Qurani</span>
      </div>

    </div>
  </div>
</section>
