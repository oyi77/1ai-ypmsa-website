---
---

<section class="section-py" style="background: var(--bg-section-dark);">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <!-- Eyebrow -->
    <span class="section-label section-label-white">Aksi Nyata</span>

    <!-- Heading -->
    <h2 class="text-3xl md:text-4xl font-bold text-white font-heading mb-4">
      Setiap Detik Berlalu, Mereka Menunggu
    </h2>
    <p class="text-white/85 text-base md:text-lg max-w-2xl mx-auto mb-3 leading-relaxed">
      250 santri bangun setiap pagi dengan semangat menghafal Al-Qur'an. Tapi tanpa dukungan Anda,
      perjuangan mereka melawan keterbatasan akan semakin berat.
    </p>
    <p class="text-lg font-semibold mb-10" style="color: var(--color-secondary-300);">
      Anda bisa menjadi alasan mereka tersenyum hari ini.
    </p>

    <div class="grid md:grid-cols-2 gap-5 max-w-3xl mx-auto">
      <!-- Card 1: Pangan Santri -->
      <div class="card-dark p-7 md:p-8 text-center">
        <div class="text-5xl mb-4">🍚</div>
        <h3 class="text-xl font-bold text-white mb-3 font-heading">
          Cukupkan Pangan Santri
        </h3>
        <p class="text-white/80 text-sm mb-7 leading-relaxed">
          Rp 50.000 cukup untuk 2 santri makan sehari. Lapar menghambat hafalan — Anda bisa
          memastikan mereka fokus ngaji dengan perut kenyang.
        </p>
        <button
          onclick="event.preventDefault();window.dispatchEvent(new CustomEvent('campaign:donate',{detail:{campaign:'sedekah-pangan-santri',campaignLabel:'Beri Makan Santri'}}));if(window.fbq)fbq('track','Donate',{content_name:'Beri Makan Santri',content_category:'CTA'});"
          class="btn-primary w-full"
        >
          Beri Makan Santri Hari Ini
        </button>
      </div>

      <!-- Card 2: Donatur Tetap -->
      <div class="p-7 md:p-8 text-center rounded-xl border-2" style="background: rgba(201,162,39,0.08); border-color: rgba(201,162,39,0.35);">
        <div class="text-5xl mb-4">📋</div>
        <h3 class="text-xl font-bold text-white mb-3 font-heading">
          Jadi Wali Santri Yatim
        </h3>
        <p class="text-white/80 text-sm mb-7 leading-relaxed">
          Rp 50.000/bulan — kurang dari Rp 1.700/hari. Jadilah orang tua asuh bagi santri yatim setiap bulannya.
        </p>
        <button
          onclick="event.preventDefault();window.dispatchEvent(new CustomEvent('campaign:donate',{detail:{campaign:'sedekah-anak-yatim',campaignLabel:'Santuni Anak Yatim'}}));if(window.fbq)fbq('track','Donate',{content_name:'Santuni Anak Yatim',content_category:'CTA'});"
          class="btn-secondary w-full"
        >
          Santuni Anak Yatim Tiap Bulan
        </button>
      </div>
    </div>

    <!-- Garis bawah + kontak -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <p class="text-white/65 text-sm">
        Ada pertanyaan? Hubungi kami via
        <a href="https://wa.me/6285655713100" onclick="if(window.fbq)fbq('track','Contact',{content_name:'CTASection WA',content_category:'CTA'});" class="font-semibold underline underline-offset-2" style="color: var(--color-secondary-300);">WhatsApp</a>
        atau lihat <a href="#faq" class="font-semibold underline underline-offset-2" style="color: var(--color-secondary-300);">FAQ</a>
      </p>
    </div>
  </div>
</section>
