---
export interface Testimonial {
  quote: string;
  author: string;
  role: string;
}

const testimonials: Testimonial[] = [
  {
    quote: 'Sedekah Rp 50.000 setiap Jumat ternyata bisa memberi makan 2 santri sehari. Rasanya ringan banget, apalagi pas lihat foto mereka belajar mengaji. Ini amal jariyah yang nyata.',
    author: 'Bapak H. Sulaiman',
    role: 'Donatur Tetap sejak 2018',
  },
  {
    quote: 'Sebelum ada donasi untuk listrik, kami belajar pakai lampu minyak kalau mati lampu. Sekarang masjid selalu terang, saya bisa setoran hafalan sampai jam 10 malam. Terima kasih untuk semua yang sudah membantu.',
    author: 'Ahmad Rizqi',
    role: 'Santri PPTQ — hafal 12 Juz',
  },
  {
    quote: 'Saya percaya karena laporan dananya detail setiap bulan — ada foto, ada rincian pengeluaran. Bukan sekadar nominal, tapi saya tahu persis bantuan saya dipakai untuk apa.',
    author: 'Ibu Dewi',
    role: 'Donatur via Program Sedekah Pangan',
  },
];
---

<section id="testimoni" class="section-py" style="background: #F0FDF9;">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <span class="section-label section-label-teal">Kata Mereka</span>
      <div class="divider-gold"></div>
      <h2 class="text-3xl md:text-4xl font-bold text-primary-900 font-heading mb-3">
        Dampak Donasi Anda
      </h2>
      <p class="text-neutral-600 max-w-xl mx-auto">
        Ribuan donatur telah merasakan kebahagiaan berbagi. Ini cerita nyata mereka.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div class="card-white flex flex-col p-6 md:p-7">
          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4" viewBox="0 0 20 20" fill="var(--color-secondary-400)">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote mark -->
          <div class="text-4xl font-bold leading-none mb-1" style="color: rgba(13,148,136,0.15); font-family: Georgia, serif;">&ldquo;</div>

          <!-- Quote text -->
          <p class="text-neutral-700 leading-relaxed text-sm md:text-base flex-1 mb-6">
            {t.quote}
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-neutral-100">
            <div class="w-10 h-10 rounded-full bg-primary-700 text-white flex items-center justify-center font-bold text-sm shrink-0">
              {t.author.charAt(0)}
            </div>
            <div>
              <div class="font-semibold text-primary-900 text-sm leading-tight">{t.author}</div>
              <div class="text-xs text-neutral-500 mt-0.5">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
