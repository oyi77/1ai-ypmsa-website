---
import { ORG_SHORT } from '../../lib/constants';
---

<section class="bg-white py-8 border-y border-neutral-100">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-center gap-8 md:gap-12 flex-wrap">
      <!-- Badge: Terdaftar di Kemenkumham -->
      <div class="flex items-center gap-3 text-neutral-600 text-sm md:text-base">
        <svg class="w-6 h-6 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span>Terdaftar di Kemenkumham</span>
      </div>

      <!-- Badge: Laporan Transparan -->
      <div class="flex items-center gap-3 text-neutral-600 text-sm md:text-base">
        <svg class="w-6 h-6 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        <span>Laporan Transparan</span>
      </div>

      <!-- Badge: Alumni -->
      <div class="flex items-center gap-3 text-neutral-600 text-sm md:text-base">
        <svg class="w-6 h-6 text-coral-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        <span>3.000+ Alumni</span>
      </div>
    </div>
  </div>
</section>
