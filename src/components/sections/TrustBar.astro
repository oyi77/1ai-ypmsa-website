---
---

<!-- TrustBar + SocialProof combined — white bg, clean -->
<section class="bg-white border-b border-neutral-100 py-5">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Social proof ticker -->
    <div class="flex flex-wrap items-center justify-center gap-5 md:gap-8 mb-4">
      <div class="flex items-center gap-2 text-sm text-neutral-500">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse-soft shrink-0"></span>
        <span><strong class="text-neutral-800">17</strong> orang berdonasi hari ini</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-neutral-500">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse-soft shrink-0"></span>
        <span><strong class="text-neutral-800">3</strong> mnt lalu — seseorang dari Surabaya berdonasi Rp 150.000</span>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="max-w-xl mx-auto mb-5">
      <div class="flex justify-between text-xs md:text-sm mb-1.5">
        <span class="font-semibold text-neutral-700">Target Bulanan</span>
        <div>
          <span class="font-bold text-coral-600">Rp 85 Juta</span>
          <span class="text-neutral-400"> / Rp 150 Juta</span>
        </div>
      </div>
      <div class="progress-bar h-2.5">
        <div class="progress-bar-fill" style="width: 57%"></div>
      </div>
      <div class="flex justify-between text-xs text-neutral-400 mt-1.5">
        <span>🎯 57% terkumpul</span>
        <span>⏳ 12 hari lagi</span>
      </div>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-5 md:gap-10 pt-3 border-t border-neutral-100">
      <div class="flex items-center gap-2 text-neutral-600 text-sm">
        <svg class="w-5 h-5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="font-medium">Terdaftar di Kemenkumham</span>
      </div>
      <div class="flex items-center gap-2 text-neutral-600 text-sm">
        <svg class="w-5 h-5 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        <span class="font-medium">Laporan Transparan</span>
      </div>
      <div class="flex items-center gap-2 text-neutral-600 text-sm">
        <svg class="w-5 h-5 text-coral-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        <span class="font-medium">3.000+ Alumni</span>
      </div>
      <div class="flex items-center gap-2 text-neutral-600 text-sm">
        <svg class="w-5 h-5 text-coral-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="font-medium"><strong>2.000+</strong> Donatur Aktif</span>
      </div>
    </div>
  </div>
</section>
