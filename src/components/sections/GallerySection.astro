---
// Gallery real conditions - YPSM Jombang

interface GalleryItem {
  src: string;
  label: string;
  span: 'normal' | 'tall' | 'wide';
}

const items: GalleryItem[] = [
  { src: '/images/campaigns/pendiri.webp', label: 'Foto Pendiri YPSM', span: 'tall' },
  { src: '/images/campaigns/IMG_1875.webp', label: 'Santriwati Saat Makan', span: 'normal' },
  { src: '/images/campaigns/IMG_1878.webp', label: 'Aktivitas Santriwati', span: 'normal' },
  { src: '/images/campaigns/IMG_1912.webp', label: 'Kondisi Dapur', span: 'normal' },
  { src: '/images/campaigns/IMG_1862.webp', label: 'Kondisi Kamar Santri', span: 'tall' },
  { src: '/images/campaigns/Berdoa.webp', label: 'Saat Berdoa Bersama', span: 'normal' },
  { src: '/images/campaigns/IMG_1829.webp', label: 'Mengaji di Bekas Garasi', span: 'tall' },
  { src: '/images/campaigns/kamar-mandi.webp', label: 'Kondisi Kamar Mandi', span: 'normal' },
  { src: '/images/campaigns/IMG_1797.webp', label: 'Suasana Belajar', span: 'normal' },
  { src: '/images/campaigns/IMG_1865.webp', label: 'Aktivitas Harian Santri', span: 'normal' },
  { src: '/images/campaigns/IMG_1883.webp', label: 'Kondisi Bangunan Tempat Tinggal', span: 'wide' },
  { src: '/images/campaigns/IMG_1898.webp', label: 'Kegiatan Santri', span: 'normal' },
  { src: '/images/campaigns/IMG_1919.webp', label: 'Kebersamaan Santri', span: 'normal' },
  { src: '/images/campaigns/IMG_1888.webp', label: 'Momen Santri', span: 'tall' },
  { src: '/images/IMG_7479.webp', label: 'Kegiatan Santri di Pondok', span: 'normal' },
  { src: '/images/IMG_7500.webp', label: 'Suasana Belajar Santri', span: 'tall' },
  { src: '/images/IMG_7521.webp', label: 'Aktivitas Harian Pondok', span: 'normal' },
  { src: '/images/IMG_7540.webp', label: 'Kegiatan Bersama Santriwati', span: 'normal' },
  { src: '/images/IMG_7558.webp', label: 'Momen Kebersamaan', span: 'wide' },
  { src: '/images/IMG_7593.webp', label: 'Proses Belajar Mengajar', span: 'tall' },
  { src: '/images/IMG_7629.webp', label: 'Suasana Pondok Pesantren', span: 'normal' },
  { src: '/images/IMG_7663.webp', label: 'Aktivitas Belajar Santri', span: 'normal' },
  { src: '/images/IMG_7680.webp', label: 'Kegiatan Santri di Luar Kelas', span: 'tall' },
  { src: '/images/IMG_7731.webp', label: 'Momen Istirahat Santri', span: 'normal' },
  { src: '/images/IMG_7768.webp', label: 'Keseharian di Pondok', span: 'wide' },
  { src: '/images/IMG_8915.webp', label: 'Kegiatan Ekstrakurikuler', span: 'normal' },
];

// Natural sort: tall+wide items first for better layout
const sorted = [...items].sort((a, b) => {
  const order = { tall: 0, wide: 1, normal: 2 };
  return order[a.span] - order[b.span];
});
---

<section class="py-20 bg-neutral-50" id="galeri">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="inline-block text-sm font-semibold text-coral-500 uppercase tracking-widest mb-3" data-i18n="gallery.badge">Galeri</span>
      <h2 class="text-3xl md:text-4xl font-bold text-primary-900 font-heading mb-4" data-i18n="gallery.title">
        Kondisi Nyata YPSM Jombang
      </h2>
      <p class="text-neutral-500 max-w-2xl mx-auto" data-i18n="gallery.subtitle">
        Dokumentasi aktivitas dan kondisi santri di Yayasan Pendidikan &amp; Sosial Ma'arif
      </p>
    </div>

    <!-- Masonry Photo Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 auto-rows-[160px] md:auto-rows-[200px]">
      {
        sorted.map((item) => (
          <a
            href={item.src}
            target="_blank"
            class="group relative rounded-xl overflow-hidden bg-neutral-200 block"
            class:list={[
              item.span === 'tall' && 'row-span-2',
              item.span === 'wide' && 'col-span-2',
            ]}
          >
            <img
              src={item.src}
              alt={item.label}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
              <span class="text-white font-semibold text-sm leading-tight">{item.label}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
