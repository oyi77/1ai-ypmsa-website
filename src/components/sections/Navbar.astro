---
import LanguageSwitcher from '../islands/LanguageSwitcher.tsx';
import { SITE_NAME, NAV_ITEMS } from '../../lib/constants';
---

<header
  id="site-navbar"
  class="fixed top-0 left-0 right-0 z-[var(--z-navbar)] glass border-b border-white/20"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img
          src="/logo-ypsma.webp"
          alt={SITE_NAME}
          class="h-8 w-auto lg:h-10"
          width="40"
          height="40"
        />
        <span class="nav-logo-text text-base lg:text-lg font-bold text-primary-900 font-heading leading-tight">
          YPSM<br class="hidden sm:block" /><span class="text-xs font-normal text-neutral-500 hidden sm:block">Jombang</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden lg:flex items-center gap-6">
        {
          NAV_ITEMS.map((item) => (
            <li>
              <a
                href={item.href}
                class="nav-link text-neutral-700 hover:text-primary-600 transition-colors duration-200 font-medium text-sm py-1 border-b-2 border-transparent hover:border-primary-500"
                data-i18n={`nav.${item.label.toLowerCase().replace(/[\s/]+/g, '-').replace(/[^a-z0-9-]/g, '')}`}
              >{item.label}</a>
            </li>
          ))
        }
      </ul>

      <!-- Desktop right actions -->
      <div class="hidden lg:flex items-center gap-3">
        <LanguageSwitcher client:load />
        <a
          id="donate-nav-cta"
          href="/donasi/"
          class="btn-primary !py-2.5 !px-5 !text-sm !shadow-none"
          data-i18n="nav.donate"
        >
          ❤️ Donasi Sekarang
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="nav-toggle"
        class="lg:hidden p-2 text-neutral-700 hover:text-primary-700 transition-colors rounded-lg hover:bg-neutral-100"
        aria-label="Toggle navigation menu"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line id="hamburger-line1" x1="3" y1="7" x2="21" y2="7" />
          <line id="hamburger-line2" x1="3" y1="12" x2="21" y2="12" />
          <line id="hamburger-line3" x1="3" y1="17" x2="21" y2="17" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Drawer Overlay -->
<div
  id="nav-overlay"
  class="fixed inset-0 bg-black/50 z-[calc(var(--z-navbar)+1)] opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
  aria-hidden="true"
></div>

<!-- Mobile Drawer -->
<aside
  id="nav-drawer"
  class="fixed top-0 left-0 h-full w-72 max-w-[85vw] bg-white z-[calc(var(--z-navbar)+2)] -translate-x-full transition-transform duration-300 ease-in-out lg:hidden shadow-strong"
  aria-label="Mobile navigation"
>
  <div class="flex flex-col h-full">
    <!-- Drawer header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-100 bg-primary-900">
      <div class="flex items-center gap-3">
        <img src="/logo-ypsma.webp" alt={SITE_NAME} class="h-8 w-auto" width="32" height="32" />
        <span class="font-bold text-white font-heading text-sm">YPSM Jombang</span>
      </div>
      <button
        id="nav-close"
        class="p-1.5 rounded-lg text-white/70 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Close navigation menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 overflow-y-auto px-4 py-5">
      <ul class="space-y-1">
        {
          NAV_ITEMS.map((item) => (
            <li>
              <a
                href={item.href}
                class="flex items-center gap-3 px-3 py-3 rounded-lg text-neutral-700 hover:text-primary-700 hover:bg-primary-50 transition-all font-medium text-sm"
                data-i18n={`nav.${item.label.toLowerCase().replace(/[\s/]+/g, '-').replace(/[^a-z0-9-]/g, '')}`}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Drawer CTA -->
    <div class="px-4 py-5 border-t border-neutral-100 space-y-3">
      <a
        href="/donasi/"
        class="btn-primary w-full text-center block"
      >
        ❤️ Donasi Sekarang
      </a>
      <a
        href="https://wa.me/6285655713100"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full py-2.5 rounded-lg border border-neutral-200 text-neutral-600 hover:border-primary-300 hover:text-primary-700 text-sm font-medium transition-colors"
      >
        <svg class="w-4 h-4 text-green-600" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp Pengurus
      </a>
    </div>
  </div>
</aside>

<script>
  const toggle = document.getElementById('nav-toggle');
  const close = document.getElementById('nav-close');
  const drawer = document.getElementById('nav-drawer');
  const overlay = document.getElementById('nav-overlay');
  const navbar = document.getElementById('site-navbar');

  function openMenu() {
    drawer!.classList.remove('-translate-x-full');
    overlay!.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    drawer!.classList.add('-translate-x-full');
    overlay!.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // Scroll-aware navbar
  function handleScroll() {
    if (window.scrollY > 40) {
      navbar!.classList.add('scrolled');
    } else {
      navbar!.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
