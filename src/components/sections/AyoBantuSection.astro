---
// Ayobantu campaigns data
const AYO_BANTU_CAMPAIGNS = [
  {
    title: 'Sedekah Pangan Santri Penghafal Qur\'an',
    url: 'https://www.ayobantu.com/campaign/sedekah-pangan-santri-maari',
    donateUrl: 'https://www.ayobantu.com/campaign/sedekah-pangan-santri-maari/donate',
    icon: '',
  },
  {
    title: 'Sedekah Al-Qur\'an untuk Santri Penghafal',
    url: 'https://www.ayobantu.com/campaign/sedekah-quran-santri-maarif',
    donateUrl: 'https://www.ayobantu.com/campaign/sedekah-quran-santri-maarif/donate',
    icon: '',
  },
  {
    title: 'Patungan Listrik untuk Asrama Santri',
    url: 'https://www.ayobantu.com/campaign/patungan-listrik-santri-maarif',
    donateUrl: 'https://www.ayobantu.com/campaign/patungan-listrik-santri-maarif/donate',
    icon: '',
  },
];
---

<!-- AyoBantu Section — soft teal tint, fresh feel -->
<section class="section-py" style="background: #F0FDF9;">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-10">
      <span class="section-label section-label-teal">Galang Dana</span>
      <div class="divider-gold"></div>
      <h2 class="text-3xl md:text-4xl font-bold text-primary-900 font-heading mb-3">
        Galang Dana via AyoBantu
      </h2>
      <p class="text-neutral-600 max-w-xl mx-auto leading-relaxed">
        Salurkan donasi Anda melalui platform galang dana terpercaya. Aman, transparan, dan mudah.
      </p>
    </div>

    <!-- Campaign Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
      {AYO_BANTU_CAMPAIGNS.map((campaign) => (
        <a
          href={campaign.donateUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="card-white p-6 flex flex-col items-start text-left hover:border-secondary-300"
          onclick="if(window.fbq)fbq('track','ViewContent',{content_name:'{campaign.title}',content_category:'ayobantu'});"
        >
          <!-- Icon placeholder -->
          <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4" style="background: rgba(13,148,136,0.1);">
            <svg class="w-5 h-5 text-primary-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>

          <h3 class="font-bold text-primary-900 text-base mb-3 flex-1 leading-snug">{campaign.title}</h3>

          <span class="inline-flex items-center gap-1.5 text-sm font-semibold" style="color: var(--color-secondary-600);">
            Donasi via AyoBantu
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>

    <!-- View all link -->
    <div class="text-center">
      <a
        href="https://www.ayobantu.com/campaign?campaigner=YAYASAN%20PENDIDIKAN%20DAN%20SOSIAL%20MAARIF"
        target="_blank"
        rel="noopener noreferrer"
        onclick="if(window.fbq)fbq('track','ViewContent',{content_name:'ayobantu-view-all',content_category:'ayobantu'});"
        class="inline-flex items-center gap-2 text-neutral-500 hover:text-primary-600 transition-colors text-sm font-medium"
      >
        Lihat semua campaign di AyoBantu
        <svg stroke="currentColor" fill="none" viewBox="0 0 24 24" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
