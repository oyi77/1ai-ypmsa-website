---
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Image -->
  <img
    src="/images/drive-new/wisuda/wisuda-2.webp"
    alt="Santri wisuda hafidz Al-Qur'an"
    width="1920"
    height="1080"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />
  <!-- Overlay gradient — more opaque on left for text, fades right -->
  <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(13,63,60,0.94) 0%, rgba(13,63,60,0.82) 45%, rgba(13,63,60,0.55) 100%);"></div>
  <!-- Bottom fade for smooth section transition -->
  <div class="absolute bottom-0 left-0 right-0 h-24" style="background: linear-gradient(to bottom, transparent, rgba(13,63,60,0.6));"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 py-24 md:py-32 text-center">

    <!-- Eyebrow badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/90 text-xs md:text-sm px-4 py-2 rounded-full mb-6 font-medium backdrop-blur-sm">
      <span class="w-2 h-2 bg-coral-400 rounded-full animate-pulse-soft"></span>
      🚨 Sisa 12 Hari — Target Bulanan: <strong class="text-white">Rp 150 Juta</strong>
    </div>

    <!-- Headline -->
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white font-heading leading-[1.15] mb-5">
      <span class="md:hidden">Jam 03.30, Ahmad sudah bangun menghafal Al-Qur'an.</span>
      <span class="hidden md:block">
        Jam 03.30, Ahmad sudah bangun<br />
        menghafal Al-Qur'an.
        <span class="text-secondary-300"> Tapi masih belajar</span><br />
        di kamar dengan lampu redup.
      </span>
    </h1>

    <!-- Sub -->
    <p class="text-base md:text-xl text-white/85 max-w-2xl mx-auto mb-3 leading-relaxed">
      Ahmad adalah satu dari <strong class="text-white font-semibold">249 santri penghafal Qur'an</strong> yang berjuang dalam keterbatasan. Mereka menanti uluran tangan kita.
    </p>

    <!-- Impact line -->
    <p class="text-sm md:text-base text-white/75 max-w-xl mx-auto mb-8 md:mb-10">
      "Cukup <strong class="text-secondary-300 font-semibold">Rp 50.000/hari</strong> = satu santri hafidz bisa terus belajar, makan, dan tinggal di pondok."
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
      <button
        onclick="event.preventDefault();window.dispatchEvent(new CustomEvent('campaign:donate',{detail:{campaign:'general',campaignLabel:'Bantu Santri Hafidz'}}));if(window.fbq)fbq('track','Donate',{content_name:'Bantu Santri Hafidz',content_category:'Hero'});"
        class="btn-primary w-full sm:w-auto text-base md:text-lg !px-8 !py-4"
      >
        ❤️ Bantu Ahmad &amp; 249 Santri Hafidz
      </button>
      <a
        href="#program"
        class="btn-outline-white w-full sm:w-auto text-base !px-8 !py-4"
      >
        Lihat Semua Program
      </a>
    </div>

    <!-- Trust micro-badges -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4 md:gap-6">
      <div class="flex items-center gap-2 text-white/60 text-xs">
        <svg class="w-4 h-4 text-secondary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        Terdaftar Kemenkumham
      </div>
      <div class="flex items-center gap-2 text-white/60 text-xs">
        <svg class="w-4 h-4 text-secondary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        Laporan Transparan
      </div>
      <div class="flex items-center gap-2 text-white/60 text-xs">
        <svg class="w-4 h-4 text-secondary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        2.000+ Donatur Aktif
      </div>
      <div class="flex items-center gap-2 text-white/60 text-xs">
        <svg class="w-4 h-4 text-secondary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        3.000+ Alumni Berprestasi
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-white/40 animate-bounce hidden md:flex">
    <span class="text-xs">Scroll</span>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
