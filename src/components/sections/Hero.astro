---
import { ORG_SHORT } from '../../lib/constants';
---

<section class="relative min-h-[90vh] bg-gradient-primary flex items-center overflow-hidden">
  <!-- Decorative Arabic Quote -->
  <span
    class="absolute top-8 right-4 md:top-12 md:right-12 text-6xl md:text-8xl text-white/10 font-arabic leading-none select-none pointer-events-none"
    aria-hidden="true"
  >
    قُلْ إِنَّ صَلَاتِي وَنُسُكِي
  </span>

  <!-- Decorative geometric pattern (CSS) -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <div class="absolute top-1/4 -right-20 w-80 h-80 border border-white rounded-full"></div>
    <div class="absolute -bottom-20 -left-20 w-96 h-96 border border-white rounded-full"></div>
    <div class="absolute top-1/3 left-1/4 w-4 h-4 bg-white rounded-full"></div>
    <div class="absolute bottom-1/4 right-1/3 w-3 h-3 bg-white rounded-full"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 py-20 text-center">
    <!-- Gold divider -->
    <div class="h-1 w-20 bg-secondary-500 mx-auto rounded mb-6"></div>

    <!-- Heading -->
    <h1 class="text-3xl md:text-5xl font-bold text-white font-heading leading-tight mb-6">
      Mencetak Generasi Beriman, Berilmu, dan Berakhlak Mulia
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-white/80 max-w-3xl mx-auto mb-10 leading-relaxed">
      Yayasan Pendidikan &amp; Sosial Ma'arif — mengelola RA Perwanida, MI Miftahul Ulum,
      SMP Plus Ma'arif, dan PPTQ sejak 1968
    </p>

    <!-- Stat Pills -->
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      {
        [
          { value: '58 Tahun', label: 'Berdiri sejak 1968' },
          { value: '640+', label: 'Santri Aktif' },
          { value: '3000+', label: 'Alumni' },
        ].map((stat) => (
          <div
            class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-6 py-2 border border-white/20 text-white"
            title={stat.label}
          >
            <span class="font-bold text-secondary-300">{stat.value}</span>
          </div>
        ))
      }
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/donasi/"
        class="bg-coral-500 hover:bg-coral-600 text-white px-8 py-3 rounded-lg font-bold text-lg transition-all duration-200 shadow-soft hover:shadow-medium"
      >
        Donasi Sekarang
      </a>
      <a
        href="/program/"
        class="border-2 border-white/30 text-white hover:bg-white/10 px-8 py-3 rounded-lg font-semibold transition-all duration-200"
      >
        Jelajahi Program
      </a>
    </div>
  </div>
</section>
