---
---

<!-- Stats section — soft teal tint background, light feel -->
<section class="section-py" style="background: #F0FDF9;">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section heading -->
    <div class="text-center mb-12">
      <span class="section-label section-label-teal">Dampak Nyata</span>
      <h2 class="text-3xl md:text-4xl font-bold font-heading text-primary-900 mb-3">
        Perjuangan Mereka Setiap Hari
      </h2>
      <p class="text-neutral-600 max-w-2xl mx-auto leading-relaxed">
        Inilah biaya minimal yang harus kami penuhi setiap bulan untuk 250 santri. Tanpa bantuan Anda, angka-angka ini adalah beban yang terus menumpuk.
      </p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      <!-- Card 1 -->
      <div class="card-white p-6 text-center">
        <div class="w-14 h-14 mx-auto mb-4 bg-primary-50 rounded-2xl flex items-center justify-center">
          <svg class="text-primary-600" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <p class="text-3xl md:text-4xl font-bold text-primary-800 mb-1 font-heading">250</p>
        <p class="text-sm text-neutral-500 font-medium">Santri Menghafal</p>
      </div>

      <!-- Card 2 -->
      <div class="card-white p-6 text-center">
        <div class="w-14 h-14 mx-auto mb-4 bg-coral-50 rounded-2xl flex items-center justify-center">
          <svg class="text-coral-500" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <p class="text-3xl md:text-4xl font-bold text-primary-800 mb-1 font-heading">Rp 85 Jt</p>
        <p class="text-sm text-neutral-500 font-medium">Biaya Pangan/Bulan</p>
      </div>

      <!-- Card 3 -->
      <div class="card-white p-6 text-center" style="border-color: rgba(201,162,39,0.3); border-width: 2px;">
        <div class="w-14 h-14 mx-auto mb-4 bg-secondary-50 rounded-2xl flex items-center justify-center" style="background: rgba(201,162,39,0.1);">
          <svg style="color: var(--color-secondary-500);" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
          </svg>
        </div>
        <p class="text-3xl md:text-4xl font-bold font-heading mb-1" style="color: var(--color-secondary-600);">Rp 150 Jt</p>
        <p class="text-sm text-neutral-500 font-medium">Target Bulanan</p>
        <span class="inline-block mt-2 text-xs font-bold px-2 py-0.5 rounded-full" style="background: rgba(201,162,39,0.12); color: var(--color-secondary-700);">Paling Kritis</span>
      </div>

      <!-- Card 4 -->
      <div class="card-white p-6 text-center">
        <div class="w-14 h-14 mx-auto mb-4 bg-green-50 rounded-2xl flex items-center justify-center">
          <svg class="text-green-600" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
            <line x1="9" y1="9" x2="9.01" y2="9"/>
            <line x1="15" y1="9" x2="15.01" y2="9"/>
          </svg>
        </div>
        <p class="text-3xl md:text-4xl font-bold text-primary-800 mb-1 font-heading">1.000+</p>
        <p class="text-sm text-neutral-500 font-medium">Donatur Aktif</p>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-10">
      <p class="text-neutral-600 mb-4">
        Kita masih butuh <strong class="text-coral-600">Rp 65 juta lagi</strong> untuk bulan ini. Setiap donasi berarti.
      </p>
      <button
        onclick="event.preventDefault();window.dispatchEvent(new CustomEvent('campaign:donate',{detail:{campaign:'sedekah-pangan-santri',campaignLabel:'Bantu Pangan Santri'}}));if(window.fbq)fbq('track','Donate',{content_name:'Stats CTA',content_category:'stats'});"
        class="btn-primary"
      >
        🍚 Bantu Tutup Kekurangan Dana
      </button>
    </div>
  </div>
</section>
