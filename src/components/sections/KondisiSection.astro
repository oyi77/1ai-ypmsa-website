---

<!-- Kondisi section — soft teal tint background so text is fully readable -->
<section id="kondisi" class="section-py" style="background: #F0FDF9;">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-10">
      <span class="section-label section-label-teal">Kondisi Nyata</span>
      <div class="divider-gold"></div>
      <h2 class="text-3xl md:text-4xl font-bold text-primary-900 font-heading mb-3">
        Kondisi Santri Kita
      </h2>
      <p class="text-neutral-600 max-w-2xl mx-auto leading-relaxed">
        Inilah kondisi nyata yang kami hadapi setiap hari. Program donasi kami lahir dari kebutuhan
        ini — bukan dari meja rapat, tapi dari lapangan.
      </p>
    </div>

    <!-- Featured Card — Pangan Santri (most urgent) -->
    <div class="mb-6">
      {(() => {
        const item = kondisi[0];
        return (
          <a
            href={`/program/${item.slug}`}
            onclick={`if(window.fbq)fbq('track','ViewContent',{content_name:'${item.slug}',content_category:'kondisi-featured'});`}
            class="group block bg-white rounded-2xl overflow-hidden border border-primary-100 hover:border-coral-400/50 shadow-soft hover:shadow-medium transition-all duration-300"
          >
            <div class="md:grid md:grid-cols-2 md:items-stretch">
              <!-- Photo -->
              <div class="relative h-56 md:h-full overflow-hidden img-zoom">
                <img
                  src={item.photo}
                  alt={item.alt}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="600"
                  height="400"
                />
                <!-- Badge -->
                <div class="absolute top-4 left-4">
                  <span class="bg-coral-500 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-soft">🔥 Paling Kritis</span>
                </div>
              </div>

              <!-- Text -->
              <div class="p-5 md:p-7 flex flex-col justify-center">
                <span class="text-4xl mb-2">{item.icon}</span>
                <span class="text-xs font-bold uppercase tracking-wider text-primary-500 mb-1">{item.programLabel}</span>
                <h3 class="text-xl font-bold text-primary-900 font-heading mb-2 leading-snug">{item.title}</h3>
                <p class="text-neutral-600 text-sm mb-4 leading-relaxed">{item.subtitle}</p>

                <!-- Stats row -->
                <div class="flex flex-wrap gap-x-6 gap-y-1 mb-4">
                  {item.stats.map(s => (
                    <div class="flex items-baseline gap-1">
                      <span class="text-lg font-bold text-primary-700">{s.value}</span>
                      <span class="text-xs text-neutral-500">{s.label}</span>
                    </div>
                  ))}
                </div>

                <!-- Progress bar -->
                <div class="mb-2">
                  <div class="flex justify-between text-xs text-neutral-400 mb-1">
                    <span>Progress</span>
                    <span>Target: {item.target}</span>
                  </div>
                  <div class="progress-bar">
                    <div class="progress-bar-fill" style="width: 65%"></div>
                  </div>
                </div>

                <span class="inline-flex items-center gap-1.5 text-sm font-bold text-coral-600 mt-2 group-hover:gap-2 transition-all">
                  {item.cta}
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        );
      })()}
    </div>

    <!-- Remaining Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {kondisi.slice(1).map((item) => (
        <a
          href={`/program/${item.slug}`}
          onclick={`if(window.fbq)fbq('track','ViewContent',{content_name:'${item.slug}',content_category:'kondisi-grid'});`}
          class="card-white p-5 flex flex-col hover:border-primary-200"
        >
          <div class="flex items-start gap-3 mb-2">
            <span class="text-3xl shrink-0">{item.icon}</span>
            <div class="min-w-0">
              <span class="text-xs font-bold uppercase tracking-wider text-primary-500">{item.programLabel}</span>
              <h3 class="text-sm font-bold text-primary-900 leading-snug mt-0.5">{item.title}</h3>
            </div>
          </div>

          <p class="text-xs text-neutral-500 mb-3 flex-1 leading-relaxed">{item.subtitle}</p>

          <!-- Stats -->
          <div class="flex flex-wrap gap-x-4 gap-y-0.5 mb-3">
            {item.stats.map(s => (
              <div class="flex items-baseline gap-1">
                <span class="font-bold text-primary-700 text-xs">{s.value}</span>
                <span class="text-xs text-neutral-400">{s.label}</span>
              </div>
            ))}
          </div>

          <!-- CTA -->
          <span class="text-sm font-bold text-coral-600 flex items-center gap-1.5">
            {item.cta}
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-10">
      <a
        href="#donasi"
        class="btn-primary"
        onclick="if(window.fbq)fbq('track','Donate',{content_name:'Kondisi Bottom CTA',content_category:'kondisi'});"
      >
        Salurkan Donasi Sekarang
      </a>
    </div>
  </div>
</section>
