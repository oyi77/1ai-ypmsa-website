---

<section id="kondisi" class="bg-primary-900 text-white py-20">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-6">
      <h2 class="text-3xl md:text-4xl font-bold font-title mb-4">
        Kondisi Santri Kita
      </h2>
      <p class="text-white/70 max-w-2xl mx-auto">
        Inilah kondisi nyata yang kami hadapi setiap hari. Program donasi kami lahir dari kebutuhan
        ini — bukan dari meja rapat, tapi dari lapangan.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        kondisi.map((item) => (
          <a
            href={`/program/${item.slug}`}
            class="group block bg-white/5 hover:bg-white/10 rounded-xl overflow-hidden border border-white/10 hover:border-coral-500/50 transition-all duration-300"
          >
            <!-- Image -->
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={item.photo}
                alt={item.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>

            <!-- Content -->
            <div class="p-5">
              <div class="flex items-start gap-3 mb-2">
                <span class="text-xl shrink-0 mt-0.5">{item.icon}</span>
                <h3 class="font-bold text-base leading-snug">{item.title}</h3>
              </div>
              <p class="text-white/60 text-sm leading-relaxed mb-4">{item.body}</p>
              <span class="inline-flex items-center gap-1 text-coral-400 font-semibold text-sm group-hover:gap-2 transition-all">
                Donasi Sekarang
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <a
        href="/program"
        class="inline-flex items-center gap-2 px-8 py-4 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-full transition-all text-lg"
      >
        Lihat Semua Program Donasi
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
