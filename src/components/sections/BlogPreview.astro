---
import { ORG_SHORT } from '../../lib/constants';

const posts = [
  {
    date: '15 Juni 2026',
    title: 'Santri Baru RA Perwanida Tahun Ajaran 2026-2027',
    excerpt: 'RA Perwanida YPSM Jombang membuka pendaftaran santri baru tahun ajaran 2026-2027. Program pendidikan usia dini Islami untuk membangun generasi beriman dan berakhlak.',
    image: null,
  },
  {
    date: '28 Mei 2026',
    title: 'Kegiatan Pesantren Kilat MI Miftahul Ulum',
    excerpt: 'MI Miftahul Ulum menggelar pesantren kilat selama bulan Ramadhan. Siswa mengikuti berbagai kegiatan keagamaan dan pembentukan karakter Islami.',
    image: null,
  },
  {
    date: '10 April 2026',
    title: 'Wisuda Tahfidz ke-5 PPTQ YPSM',
    excerpt: 'PPTQ YPSM menggelar wisuda tahfidz ke-5 dengan 25 hafidz dan hafidzah baru. Acara berlangsung khidmat dihadiri oleh orang tua dan dewan pembina yayasan.',
    image: null,
  },
];
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-12">
      <h2 class="section-heading section-heading-center text-3xl md:text-4xl text-primary-900 inline-block" data-i18n="blog.title">
        Cerita &amp; Kegiatan Terbaru
      </h2>
      <p class="text-neutral-600 mt-4 max-w-2xl mx-auto" data-i18n="blog.subtitle">
        Ikuti perjalanan YPSM dalam mendidik generasi penerus
      </p>
    </div>

    <!-- Blog Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        posts.map((post) => (
          <article class="bg-white shadow-soft rounded-xl overflow-hidden card-hover flex flex-col">
            <!-- Image Placeholder -->
            <div class="bg-neutral-200 h-48 flex items-center justify-center">
              <svg class="w-12 h-12 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>

            <!-- Content -->
            <div class="p-5 flex flex-col flex-1">
              <!-- Date Badge -->
              <span class="text-xs font-semibold text-secondary-700 bg-secondary-50 rounded-full px-3 py-1 inline-block w-fit mb-3">
                {post.date}
              </span>

              <!-- Title -->
              <h3 class="font-heading text-lg font-bold text-primary-900 mb-2 leading-snug">
                {post.title}
              </h3>

              <!-- Excerpt -->
              <p class="text-neutral-600 text-sm mb-4 flex-1">
                {post.excerpt}
              </p>

              <!-- Read More Link -->
              <a
                href="/cerita-dampak/"
                class="text-coral-500 font-semibold text-sm hover:underline inline-flex items-center gap-1 mt-auto"
              >
                <span data-i18n="blog.readMore">Baca Selengkapnya</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <!-- See All Link -->
    <div class="text-center mt-12">
      <a
        href="/cerita-dampak/"
        class="inline-flex items-center gap-2 text-primary-700 font-semibold hover:text-primary-900 transition-colors"
      >
        <span data-i18n="blog.seeAll">Lihat Semua Kegiatan</span>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
