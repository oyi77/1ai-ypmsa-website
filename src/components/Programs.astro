---
// Programs Section - Academic and extracurricular programs
---

<section id="program" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-gray-900 mb-4">
        Program Unggulan
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-accent-500 mx-auto rounded-full mb-6"></div>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Pilihan program pendidikan yang dirancang untuk mengembangkan potensi siswa secara komprehensif
      </p>
    </div>

    <!-- Tab Navigation -->
    <div class="flex justify-center mb-12">
      <div class="inline-flex bg-white rounded-xl p-1 shadow-sm border border-gray-200">
        <button class="program-tab active px-6 py-3 rounded-lg text-sm font-semibold transition-all" data-tab="reguler">
          Program Reguler
        </button>
        <button class="program-tab px-6 py-3 rounded-lg text-sm font-semibold transition-all text-gray-500 hover:text-gray-700" data-tab="unggulan">
          Program Unggulan
        </button>
        <button class="program-tab px-6 py-3 rounded-lg text-sm font-semibold transition-all text-gray-500 hover:text-gray-700" data-tab="ekskul">
          Ekstrakurikuler
        </button>
      </div>
    </div>

    <!-- Program Reguler -->
    <div id="tab-reguler" class="program-content">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- SD -->
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
          <div class="h-48 bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">Sekolah Dasar (SD)</h3>
            <p class="text-gray-500 text-sm mb-4">Kelas 1 - 6</p>
            <ul class="space-y-2 text-gray-600 text-sm">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Kurikulum Merdeka
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Tahfidz Al-Qur'an
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Bahasa Inggris & Arab
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Pembelajaran Berbasis Lingkungan
              </li>
            </ul>
            <a href="#kontak" class="mt-6 inline-flex items-center text-primary-600 font-semibold hover:text-primary-700 transition-colors group/link">
              Daftar Sekarang
              <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>

        <!-- SMP -->
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
          <div class="h-48 bg-gradient-to-br from-accent-400 to-accent-600 flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">Sekolah Menengah (SMP)</h3>
            <p class="text-gray-500 text-sm mb-4">Kelas 7 - 9</p>
            <ul class="space-y-2 text-gray-600 text-sm">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Kurikulum Merdeka
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Tahfidz Al-Qur'an Level Lanjutan
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Sains & Teknologi
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Konservasi Alam
              </li>
            </ul>
            <a href="#kontak" class="mt-6 inline-flex items-center text-accent-600 font-semibold hover:text-accent-700 transition-colors group/link">
              Daftar Sekarang
              <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>

        <!-- SMA -->
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
          <div class="h-48 bg-gradient-to-br from-secondary-400 to-secondary-600 flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">Sekolah Menengah Atas (SMA)</h3>
            <p class="text-gray-500 text-sm mb-4">Kelas 10 - 12</p>
            <ul class="space-y-2 text-gray-600 text-sm">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Kurikulum Merdeka + Internasional
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Persiapan PTN & Beasiswa
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Penelitian Ilmiah
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Program Kepemimpinan
              </li>
            </ul>
            <a href="#kontak" class="mt-6 inline-flex items-center text-secondary-600 font-semibold hover:text-secondary-700 transition-colors group/link">
              Daftar Sekarang
              <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Program Unggulan (hidden by default) -->
    <div id="tab-unggulan" class="program-content hidden">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Tahfidz -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all border border-gray-100">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center">
              <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-bold text-gray-900">Program Tahfidz Al-Qur'an</h3>
          </div>
          <p class="text-gray-600 mb-4">Hafalan Al-Qur'an dengan metode Muraja'ah dan pendampingan intensif oleh ustadz/ustadzah berpengalaman. Target hafalan 1-3 juz per tahun.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-medium">Tahfidz</span>
            <span class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-medium">Muraja'ah</span>
            <span class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-medium">1-3 Juz/Tahun</span>
          </div>
        </div>

        <!-- Konservasi -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all border border-gray-100">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-14 h-14 bg-accent-100 rounded-xl flex items-center justify-center">
              <svg class="w-7 h-7 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-bold text-gray-900">Program Konservasi Alam</h3>
          </div>
          <p class="text-gray-600 mb-4">Pembelajaran berbasis lingkungan hidup untuk melestarikan keindahan alam Sumba. Siswa aktif dalam program penghijauan dan konservasi hayati.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-accent-50 text-accent-700 rounded-full text-xs font-medium">Lingkungan</span>
            <span class="px-3 py-1 bg-accent-50 text-accent-700 rounded-full text-xs font-medium">Penghijauan</span>
            <span class="px-3 py-1 bg-accent-50 text-accent-700 rounded-full text-xs font-medium">Sumba</span>
          </div>
        </div>

        <!-- Leadership -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all border border-gray-100">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-14 h-14 bg-secondary-100 rounded-xl flex items-center justify-center">
              <svg class="w-7 h-7 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-bold text-gray-900">Program Kepemimpinan</h3>
          </div>
          <p class="text-gray-600 mb-4">Pengembangan soft skills dan karakter kepemimpinan melalui kegiatan organisasi, seminar, dan project-based learning.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-secondary-50 text-secondary-700 rounded-full text-xs font-medium">Leadership</span>
            <span class="px-3 py-1 bg-secondary-50 text-secondary-700 rounded-full text-xs font-medium">Soft Skills</span>
            <span class="px-3 py-1 bg-secondary-50 text-secondary-700 rounded-full text-xs font-medium">Project-Based</span>
          </div>
        </div>

        <!-- Language -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all border border-gray-100">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center">
              <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-bold text-gray-900">Program Bilingual</h3>
          </div>
          <p class="text-gray-600 mb-4">Pembelajaran intensif Bahasa Inggris dan Bahasa Arab untuk mempersiapkan siswa bersaing di era global.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-medium">English</span>
            <span class="px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-medium">Arabic</span>
            <span class="px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-medium">Bilingual</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ekstrakurikuler (hidden by default) -->
    <div id="tab-ekskul" class="program-content hidden">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
        {[
          { name: 'Pramuka', icon: '🏕️', color: 'bg-green-50 text-green-700 border-green-200' },
          { name: 'Tilawah', icon: '📖', color: 'bg-primary-50 text-primary-700 border-primary-200' },
          { name: 'Olahraga', icon: '⚽', color: 'bg-blue-50 text-blue-700 border-blue-200' },
          { name: 'Seni Budaya', icon: '🎨', color: 'bg-purple-50 text-purple-700 border-purple-200' },
          { name: 'Robotik', icon: '🤖', color: 'bg-orange-50 text-orange-700 border-orange-200' },
          { name: 'Palang Merah', icon: '🩺', color: 'bg-red-50 text-red-700 border-red-200' },
          { name: 'Konservasi', icon: '🌿', color: 'bg-emerald-50 text-emerald-700 border-emerald-200' },
          { name: 'Bahasa Inggris', icon: '🌍', color: 'bg-sky-50 text-sky-700 border-sky-200' },
          { name: 'Qiro\'ati', icon: '🕌', color: 'bg-amber-50 text-amber-700 border-amber-200' },
          { name: 'Musik', icon: '🎵', color: 'bg-pink-50 text-pink-700 border-pink-200' },
        ].map(item => (
          <div class={`rounded-xl border-2 p-4 text-center hover:shadow-lg transition-all cursor-pointer ${item.color}`}>
            <div class="text-4xl mb-3">{item.icon}</div>
            <h4 class="font-semibold">{item.name}</h4>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Tab switching
  const tabs = document.querySelectorAll('.program-tab');
  const contents = document.querySelectorAll('.program-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-target');
      
      // Update active tab style
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-primary-500', 'text-white');
        t.classList.add('text-gray-500');
      });
      tab.classList.add('active', 'bg-primary-500', 'text-white');
      tab.classList.remove('text-gray-500');
      
      // Show/hide content
      contents.forEach(content => {
        content.classList.add('hidden');
      });
      document.getElementById(`tab-${target}`)?.classList.remove('hidden');
    });
  });

  // Set initial active tab style
  const activeTab = document.querySelector('.program-tab.active');
  if (activeTab) {
    activeTab.classList.add('bg-primary-500', 'text-white');
    activeTab.classList.remove('text-gray-500');
  }
</script>
