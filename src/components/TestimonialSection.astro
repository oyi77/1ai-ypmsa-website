---
/**
 * TestimonialSection — Apa Kata Mereka?
 * 3 testimonial cards with gold border-l, star rating, avatar initials
 * Zero client-side JS
 */

const testimonials = [
  {
    quote: 'Alhamdulillah, anak saya berkembang pesat di YPSMA. Tidak hanya pintar secara akademik, tapi juga memiliki akhlak yang mulia. Guru-gurunya sangat perhatian dan profesional.',
    name: 'Ibu Siti Rahmawati',
    role: 'Orang Tua',
    initials: 'SR',
    color: 'bg-[var(--color-primary-500)]',
    stars: 5,
  },
  {
    quote: 'Saya bersyukur pernah belajar di YPSMA. Ilmu yang diperoleh menjadi pondasi kuat dalam kuliah dan karier. Metode Tahfidz-nya luar biasa membentuk disiplin diri.',
    name: 'Ahmad Fauzi, S.Kom',
    role: 'Alumni',
    initials: 'AF',
    color: 'bg-[var(--color-secondary-500)]',
    stars: 5,
  },
  {
    quote: 'Bergabung dengan YPSMA adalah keputusan terbaik. Budaya belajar Islam terpadu di sini benar-benar diterapkan, bukan sekadar label. Lingkungannya sangat mendukung.',
    name: 'Ustadzah Nurhaliza, M.Pd',
    role: 'Guru',
    initials: 'NH',
    color: 'bg-[var(--color-accent-rose)]',
    stars: 5,
  },
];
---

<section id="testimoni" class="bg-[var(--color-neutral-50)] py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mx-auto mb-12 max-w-2xl text-center md:mb-16">
      <span class="mb-3 inline-block rounded-full bg-[var(--color-primary-50)] px-4 py-1.5 font-[var(--font-heading)] text-sm font-semibold tracking-wide text-[var(--color-primary-600)]">
        Testimoni
      </span>
      <h2 class="mb-3 font-[var(--font-heading)] text-3xl font-extrabold tracking-tight text-[var(--color-neutral-900)] sm:text-4xl">
        Apa Kata Mereka?
      </h2>
      <div class="mx-auto h-1 w-16 rounded-full bg-[var(--color-secondary-500)]"></div>
    </div>

    <!-- Testimonial Cards -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3">
      {testimonials.map((t) => (
        <article class="relative rounded-lg border-l-4 border-[var(--color-secondary-500)] bg-white p-6 shadow-[var(--shadow-soft)] transition-shadow duration-300 hover:shadow-[var(--shadow-md)] md:p-8">
          <!-- Star Rating -->
          <div class="mb-4 flex gap-1" aria-label={`Rating ${t.stars} dari 5 bintang`}>
            {Array.from({ length: t.stars }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[var(--color-secondary-500)]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="mb-6 text-[var(--color-neutral-700)] leading-relaxed">
            <svg xmlns="http://www.w3.org/2000/svg" class="mb-2 h-6 w-6 text-[var(--color-secondary-300)]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.69 11 13.166 11 15c0 1.933-1.567 3.5-3.5 3.5-1.168 0-2.258-.531-2.917-1.179zM14.583 17.321C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.69 21 13.166 21 15c0 1.933-1.567 3.5-3.5 3.5-1.168 0-2.258-.531-2.917-1.179z"/>
            </svg>
            <p class="text-sm leading-relaxed md:text-base">{t.quote}</p>
          </blockquote>

          <!-- Person -->
          <div class="flex items-center gap-3">
            <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full ${t.color} font-[var(--font-heading)] text-sm font-bold text-white`}>
              {t.initials}
            </div>
            <div>
              <p class="font-[var(--font-heading)] text-sm font-semibold text-[var(--color-neutral-900)]">{t.name}</p>
              <p class="text-xs text-[var(--color-neutral-500)]">{t.role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
