---
/**
 * Stats.astro — Statistik YPSMA
 * Full-width stats bar with bg-primary-700, animated count-up on scroll
 * 2 cols mobile → 4 cols desktop
 * IntersectionObserver drives the counter animation (zero framework deps)
 */
---

<section data-stats class="relative overflow-hidden bg-primary-700 py-14 md:py-20">
  <!-- ============================================================
       Subtle diagonal pattern overlay
       ============================================================ -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.07]"
    aria-hidden="true"
    style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;)"
  ></div>

  <!-- Radial glow accent -->
  <div
    class="pointer-events-none absolute -right-32 top-0 h-64 w-64 rounded-full bg-primary-500/20 blur-3xl"
    aria-hidden="true"
  ></div>

  <!-- ============================================================
       Stats grid
       ============================================================ -->
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-12">

      <!-- Stat 1: Siswa Aktif -->
      <div class="group text-center">
        <div
          class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 transition-colors group-hover:bg-white/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-white/80"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <span
          class="mb-1 block font-heading text-3xl font-bold text-white"
          data-count="180"
        >
          0<span class="text-white/70">+</span>
        </span>
        <span class="text-sm text-white/70">Siswa Aktif</span>
      </div>

      <!-- Stat 2: Guru & Staff -->
      <div class="group text-center">
        <div
          class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 transition-colors group-hover:bg-white/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-white/80"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 14a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"></path>
            <path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"></path>
          </svg>
        </div>
        <span
          class="mb-1 block font-heading text-3xl font-bold text-white"
          data-count="20"
        >
          0<span class="text-white/70">+</span>
        </span>
        <span class="text-sm text-white/70">Guru &amp; Staff</span>
      </div>

      <!-- Stat 3: Program Ekstrakurikuler -->
      <div class="group text-center">
        <div
          class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 transition-colors group-hover:bg-white/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-white/80"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
        </div>
        <span
          class="mb-1 block font-heading text-3xl font-bold text-white"
          data-count="10"
        >
          0<span class="text-white/70">+</span>
        </span>
        <span class="text-sm text-white/70">Program Ekstrakurikuler</span>
      </div>

      <!-- Stat 4: Tahun Pengalaman -->
      <div class="group text-center">
        <div
          class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 transition-colors group-hover:bg-white/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-white/80"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <span
          class="mb-1 block font-heading text-3xl font-bold text-white"
          data-count="5"
        >
          0<span class="text-white/70">+</span>
        </span>
        <span class="text-sm text-white/70">Tahun Pengalaman</span>
      </div>

    </div>
  </div>
</section>

<script>
  /**
   * Counter animation — fires once when the section scrolls into view.
   * Uses IntersectionObserver for performance (no scroll listeners).
   */
  (function () {
    const section = document.querySelector('section[data-stats]');
    if (!section) return;

    const counters = section.querySelectorAll<HTMLElement>('[data-count]');
    let hasAnimated = false;

    function animateCounters() {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.count ?? '0', 10);
        const suffix = el.querySelector('span'); // the "+" / "%" suffix element
        if (!suffix) return;

        const duration = 2000; // ms
        const stepTime = 20; // ms per frame → ~50fps
        const totalSteps = duration / stepTime;
        const increment = target / totalSteps;
        let current = 0;
        let step = 0;

        const timer = setInterval(() => {
          step++;
          current = Math.min(Math.round(increment * step), target);
          el.textContent = String(current);
          el.appendChild(suffix);

          if (step >= totalSteps) {
            clearInterval(timer);
            el.textContent = String(target);
            el.appendChild(suffix);
          }
        }, stepTime);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasAnimated) {
            hasAnimated = true;
            animateCounters();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 },
    );

    observer.observe(section);
  })();
</script>
